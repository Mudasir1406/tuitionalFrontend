# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real secrets.

# App environment — controls which Firestore database is used.
#   development → tuitional-website-staging-db (named DB)
#   production  → default DB
# Set to "development" on local + staging deployments so they use the staging DB.
# Set to "production" on the live deployment.
NEXT_PUBLIC_APP_ENV=development
